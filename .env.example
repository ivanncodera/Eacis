# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=production

# Database (PostgreSQL recommended for production)
# For local dev: sqlite:///eacis_dev.db
# For Render: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///eacis_dev.db

# Feature flags
USE_DEV_SEEDS=False

# Business settings
LOYALTY_RATE=100
RETURN_WINDOW_DAYS=7
WTF_CSRF_TIME_LIMIT=3600

# Email (SMTP) for OTP and security notifications
MAIL_ENABLED=False
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=eapplianccommerce@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_FROM_EMAIL=eapplianccommerce@gmail.com
MAIL_FROM_NAME=E-ACIS Security

# OTP controls
OTP_CODE_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_REQUESTS_PER_HOUR=8
OTP_SECRET_PEPPER=change-this-in-production
